##############################################################################
# TrainerSync Microservices — Environment Variables
# Copy this file to .env and fill in all secrets before running docker-compose.
# Lines beginning with # are comments and are NOT loaded.
##############################################################################

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://mongo:27017
MONGODB_DB_NAME=trainer_platform

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-256-bit-string

# ── CORS (comma-separated frontend origins) ───────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Gmail / SMTP ──────────────────────────────────────────────────────────────
# Either use Gmail OAuth (token.json) OR App Password — not both.
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
FROM_NAME=TrainerSync
FROM_EMAIL=your-gmail@gmail.com
# Path inside the email-service container where token.json is mounted
GOOGLE_TOKEN_FILE=config/token.json
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ── AI / LLM Keys ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# ── WhatsApp — choose ONE provider ───────────────────────────────────────────
# Provider options: twilio | aisensy | meta
WHATSAPP_PROVIDER=twilio
DEFAULT_COUNTRY_CODE=+91
VENDOR_WHATSAPP_NUMBER=+919999999999

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=+14155238886

# AiSensy
AISENSY_API_KEY=your_aisensy_api_key
AISENSY_CAMPAIGN_NAME=trainersync_campaign
AISENSY_SOURCE=TrainerSync
AISENSY_TEMPLATE_PARAM_FIELDS=message
AISENSY_TAGS=trainersync

# Meta / WhatsApp Cloud API
META_WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
META_WHATSAPP_ACCESS_TOKEN=your_access_token
META_WHATSAPP_TEMPLATE_NAME=trainer_first_contact
META_WHATSAPP_LANGUAGE_CODE=en_US
META_GRAPH_API_VERSION=v23.0

# ── Microsoft Teams ───────────────────────────────────────────────────────────
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# ── Frontend URL (used for shortlist links in Teams cards) ────────────────────
FRONTEND_URL=http://localhost:3000

# ── Internal service-to-service URLs ─────────────────────────────────────────
# These default to Docker service names — only override for non-Docker setups.
EMAIL_SERVICE_URL=http://email-service:8002
NOTIFICATION_SERVICE_URL=http://notification-service:8003

# ── Scheduler ─────────────────────────────────────────────────────────────────
INTERVIEW_REMINDER_HOURS_BEFORE=1

# ── LinkedIn / Search (optional) ──────────────────────────────────────────────
PROXYCURL_API_KEY=
SERPER_API_KEY=
