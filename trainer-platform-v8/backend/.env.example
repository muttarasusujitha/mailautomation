APP_HOST=127.0.0.1
APP_PORT=8000

FRONTEND_URL=http://localhost:5173
SECRET_KEY=

FROM_NAME=Clahan Technologies
FROM_EMAIL=your-gmail-address@gmail.com

GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# ──────────────────────────────────────────────────────────────────────────────
# Free Web Search  (zero cost — no Tavily needed)
# ──────────────────────────────────────────────────────────────────────────────
# TrainerSync discovers LinkedIn/Naukri leads using a multi-engine search stack.
# All engines are free. Adding API keys promotes them to the front of the
# waterfall for higher quality and higher volume results.
#
# Engine waterfall (auto mode — tried in priority order until results found):
#   1. Google Custom Search API  — BEST quality, 100 free queries/day,
#                                  10 real Google results per query (no bot block)
#                                  → set GOOGLE_CSE_API_KEY + GOOGLE_CSE_ID below
#   2. SerpAPI                   — Real Google results via API, 100 free/month
#                                  → set SERPAPI_KEY below
#   3. DuckDuckGo HTML scrape    — Unlimited, no key, most reliable HTML engine
#   4. Bing HTML scrape          — Unlimited, no key, multi-page support
#   5. Google HTML scrape        — Unlimited, no key, bypass tricks applied
#   6. Yahoo HTML scrape         — Unlimited, easy fallback
#   7. Ask HTML scrape           — Last resort
#
# All engines now support pagination — 20 results per query (was 5).
# Recommended setup for 100+ profiles per run:
#   • Add a free Google CSE key (takes 5 min, link below) OR a free SerpAPI key.
#   • Both have free tiers sufficient for daily lead discovery.
#
# Default: FREE_SEARCH_PROVIDER=auto (uses API engines first if keys present,
#          then falls back through HTML scrapers automatically)
# Force a specific engine: duckduckgo | bing | google | yahoo | ask | google_cse | serpapi
FREE_SEARCH_PROVIDER=auto
FREE_SEARCH_MAX_RESULTS=20
FREE_SEARCH_TIMEOUT=25

# ── Option A: Google Custom Search API (RECOMMENDED — 100 free queries/day) ──
# Setup (5 min):
#   1. Go to https://programmablesearchengine.google.com/ → Create engine
#      • "Search the entire web" = ON
#      • Note down the Search engine ID (cx value)
#   2. Go to https://console.cloud.google.com/ → APIs & Services → Credentials
#      → Create API Key → restrict to "Custom Search API"
#   3. Paste both values below and uncomment.
#
# With this key: each query returns real structured Google results (no bot block).
# 100 queries × 20 results = up to 2,000 profiles per day FREE.
#
# GOOGLE_CSE_ID=your_google_custom_search_engine_id
# GOOGLE_CSE_API_KEY=your_google_cse_api_key

# ── Option B: SerpAPI (100 free queries/month) ───────────────────────────────
# Setup: https://serpapi.com/ → Sign up → copy API key below.
# Good for supplementing Google CSE when daily quota is exhausted.
#
# SERPAPI_KEY=your_serpapi_key

# ── Option C: ScraperAPI (1,000 free requests/month) — BEST FOR BOT BYPASS ──
# This is the most impactful option if your server is on a cloud IP (AWS/GCP/Azure).
# Cloud IPs are blocked by LinkedIn, Google, and Bing for HTML scraping.
# ScraperAPI routes every request through a residential IP pool so:
#   • LinkedIn profiles load normally (no login wall)
#   • Google search returns real results (no CAPTCHA)
#   • Bing search returns real results (no 429 block)
#
# Free tier: 1,000 requests/month — roughly 100 profiles/day with no extra cost.
# Paid plans start at $29/month for 250,000 requests (unlimited profiles/day).
#
# Setup (2 min):
#   1. Go to https://www.scraperapi.com/ → Sign Up Free (no credit card needed)
#   2. Copy your API key from the dashboard
#   3. Paste it below and uncomment
#
# How it works in the code:
#   When SCRAPERAPI_KEY is set, bulk_free_search() automatically routes ALL
#   DuckDuckGo, Bing, and Google HTML scraping through ScraperAPI's residential
#   IP pool. No other code changes needed — it's fully transparent.
#
# SCRAPERAPI_KEY=your_scraperapi_key

# ── Which option should I use? ────────────────────────────────────────────────
# → Fastest setup (2 min):  ScraperAPI free tier  → 100 profiles/day
# → Best volume (5 min):    Google CSE free tier   → 1,000 profiles/day
# → Both together:          ScraperAPI + Google CSE → 2,000+ profiles/day
# → Zero setup:             No keys at all          → 5–20 profiles/day (cloud IP blocked)

# ── Legacy: Tavily (DISABLED — no longer used) ───────────────────────────────
# Tavily has been fully replaced by the multi-engine stack above.
# TAVILY_API_KEY=your-tavily-api-key

GOOGLE_CREDENTIALS_FILE=config/credentials.json
GOOGLE_TOKEN_FILE=config/token.json
