MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=trainersync

# Port the FastAPI app is bound to (used by the scheduler for internal self-calls).
# Change this if you run the app on a non-default port (e.g. behind a reverse proxy).
APP_HOST=127.0.0.1
APP_PORT=8000

FRONTEND_URL=http://localhost:5173
SECRET_KEY=

FROM_NAME=Clahan Technologies
FROM_EMAIL=your-gmail-address@gmail.com

GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Tavily Search API — for public LinkedIn/web lead search
# Free plan: 1000 searches/month
# Get your key at: https://app.tavily.com
TAVILY_API_KEY=your-tavily-api-key

GOOGLE_CREDENTIALS_FILE=config/credentials.json
GOOGLE_TOKEN_FILE=config/token.json
# Alternative to GOOGLE_CREDENTIALS_FILE: keep the OAuth client in .env.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback
PUBSUB_TOPIC=projects/your-google-cloud-project-id/topics/trainersync-inbox

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
OLLOMO_API_KEY=your_ollomo_api_key
OLLOMO_API_URL=https://api.ollomo.ai/v1/chat/completions
OLLOMO_MODEL=aiasistentworld/Llama-3.1-8B-Instruct-STO-Master:latest

TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
VENDOR_WHATSAPP_NUMBER=whatsapp:+91XXXXXXXXXX

WHATSAPP_PROVIDER=twilio
AISENSY_API_URL=https://backend.aisensy.com/campaign/t1/api/v2
AISENSY_API_KEY=your_aisensy_api_key
AISENSY_CAMPAIGN_NAME=trainersync_notify
AISENSY_SOURCE=TrainerSync
AISENSY_TEMPLATE_PARAM_FIELDS=message
AISENSY_TAGS=trainersync
META_GRAPH_API_VERSION=v23.0
META_WHATSAPP_PHONE_NUMBER_ID=your_meta_phone_number_id
META_WHATSAPP_ACCESS_TOKEN=your_meta_access_token
META_WHATSAPP_TEMPLATE_NAME=trainersync_notify
META_WHATSAPP_LANGUAGE_CODE=en_US
META_WHATSAPP_TEMPLATE_PARAM_FIELDS=message

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

TEAMS_WEBHOOK_URL=your_teams_webhook_url
